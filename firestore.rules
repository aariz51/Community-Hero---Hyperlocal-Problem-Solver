rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /reports/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    match /users/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
