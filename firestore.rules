rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /reports/{id} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if signedIn();
    }

    match /users/{id} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == id;
    }

    match /agent_runs/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /agent_steps/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /agent_actions/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /agent_memory/{id} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /verification_evidence/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
